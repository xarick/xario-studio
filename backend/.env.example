DATABASE_URL=postgresql://postgres:postgres@localhost:5432/xario_db
FRONTEND_URL=http://localhost:5173
DEBUG=True
SECRET_KEY=change-me-in-production

# ── Super admin (migration 0003 da bir marta yaratiladi) ─────────────────────
# "make migrate" ishga tushirganda shu ma'lumotlar bilan super admin yaratiladi
SUPER_ADMIN_USERNAME=admin
# MAJBURIY: DEBUG=false bo'lganda ilova standart parol bilan ishga tushmaydi
# (bu repo public — standart parol hammaga ma'lum). 0003 migratsiyasi har safar
# superadmin parolini shu qiymatga qayta o'rnatadi.
SUPER_ADMIN_PASSWORD=Admin123

# Storage paths (relative to backend root)
UPLOAD_DIR=storage/uploads
OUTPUT_DIR=storage/outputs

# ── Job queue (Celery + Redis) ───────────────────────────────────────────────
# Og'ir ML joblar alohida worker processda bajariladi (web process bloklanmaydi).
# Worker'ni ishga tushirish: make worker   (Redis kerak: docker run -p 6379:6379 redis)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
WORKER_CONCURRENCY=1              # bir vaqtda nechta job (ML og'ir → 1 tavsiya)
# Redis/worker'siz tez sinash uchun: joblar web process ichida bajariladi
CELERY_TASK_ALWAYS_EAGER=False
# Ikki navbat: og'ir ML joblar yengil ffmpeg joblarni bloklamasligi uchun.
CELERY_QUEUE_MEDIA=media
CELERY_QUEUE_HEAVY=heavy

# Processing limits
MIN_SHORT_DURATION=30
MAX_SHORT_DURATION=60
SIMPLE_MIN_DURATION=45        # Simple rejim: shortlar 45–60s oralig'ida o'zgaradi
MAX_SHORTS_COUNT=10
MAX_UPLOAD_SIZE_MB=500

# ffmpeg watchdog: max(MIN, media_seconds * FACTOR). Osilib qolgan encoderni
# ushlaydi; uzun videoni o'ldirmasligi uchun budjet media uzunligiga qarab o'sadi.
FFMPEG_MIN_TIMEOUT=600
FFMPEG_TIMEOUT_FACTOR=6.0

# ── Smart highlight generation (generation_mode=smart) ───────────────────────
# Smart rejim: scene almashinuvi + nutq zichligi bo'yicha muhim lahzalar topiladi
SCENE_DETECT_THRESHOLD=0.27   # 0–1, kichikroq = ko'proq sahna kesimi
SMART_CLIP_MIN=5              # eng qisqa highlight bo'lagi (s)
SMART_CLIP_MAX=12             # eng uzun highlight bo'lagi (s)

# ── Subtitrlar (faster-whisper bilan) ────────────────────────────────────────
SUBTITLE_STYLE=karaoke        # karaoke (so'zlar gapirilganda yonadi) | plain
SUBTITLE_WORDS_PER_LINE=4
WHISPER_MODEL_SIZE=base       # tiny | base | small | medium | large-v3 (yoki CT2 repo/papka)
WHISPER_DEVICE=cpu            # cpu | cuda (GPU bo'lmasa avto CPU'ga qaytadi)
WHISPER_COMPUTE_TYPE=         # bo'sh=auto (cpu→int8, cuda→int8_float16); yoki float16/int8
WHISPER_LANGUAGE=             # bo'sh = avto; yoki "uz", "ru", "en"
# GPU uchun: pip install nvidia-cublas-cu12 "nvidia-cudnn-cu12>=9,<10" (kod ularni avto yuklaydi)
# Ollama bilan VRAM bo'lishganda int8_float16 tavsiya etiladi (kamroq VRAM)

# ── image_to_shorts (rasmlardan 9:16 short) — ffmpeg, kalit kerak emas ────────
SLIDESHOW_SECONDS_PER_IMAGE=3.5
SLIDESHOW_TRANSITION=0.6
SLIDESHOW_MAX_IMAGES=20

# ── AI Provider ─────────────────────────────────────────────────────────────
# Quyidagi variantlardan birini tanlang:

# 1) Ollama (local, bepul) — ollama pull llama3.1:8b
AI_PROVIDER=ollama
AI_API_KEY=ollama
AI_MODEL=qwen3:8b
AI_BASE_URL=http://localhost:11434/v1

# 2) OpenAI
# AI_PROVIDER=openai
# AI_API_KEY=sk-...
# AI_MODEL=gpt-4o-mini
# AI_BASE_URL=

# 3) Google Gemini
# AI_PROVIDER=gemini
# AI_API_KEY=AIza...
# AI_MODEL=gemini-1.5-flash
# AI_BASE_URL=
